# MANAGED BY ANSIBLE — users role. Do not edit by hand.
# Oh My Zsh is installed SHARED (system-wide); this file points at it.
export ZSH="{{ users_zsh_ohmyzsh_dir }}"

# Cache and .zcompdump go to a per-user writable location (because $ZSH is read-only).
export ZSH_CACHE_DIR="$HOME/.cache/oh-my-zsh"

# Shared/read-only install — auto-update is disabled (a user cannot pull the root-owned repo).
export DISABLE_AUTO_UPDATE="true"

ZSH_THEME="{{ users_zsh_theme }}"

plugins=(
{% for plugin in users_zsh_plugins %}
  {{ plugin }}
{% endfor %}
)

source $ZSH/oh-my-zsh.sh

export PATH=$HOME/bin:/usr/local/bin:$PATH
